rules_version = '2';

// RADYVORA — Firestore Güvenlik Kuralları
// Bu dosyanın TAMAMINI Firebase Console > Firestore Database > Rules
// sekmesine yapıştır ve "Yayınla" (Publish) de bas.
//
// Mantık: Her kullanıcı SADECE kendi UID'si altındaki belgeleri
// okuyabilir ve yazabilir. Başka bir kullanıcının verisine
// hiçbir koşulda erişilemez — giriş yapmamış biri de hiçbir şey
// okuyamaz/yazamaz.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {

      match /companies/{companyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // İleride eklenecek alt koleksiyonlar (yatırım günlüğü vb.)
      // için de aynı desen kullanılacak:
      match /journal/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Yukarıda listelenmeyen her şey kapalı.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
